# Copy this file to .env and fill in real values: `cp .env.example .env`
# .env is loaded automatically on startup (via dotenv), for both `npm start`
# and Docker Compose. Restart the server after changing any value here.

# --- Core ---
PORT=3000
NODE_ENV=production
# Host port Docker publishes the app on (the container always listens on 3000).
# On the Pi set HOST_PORT=3002, since Homepage already uses port 3000 there.
# HOST_PORT=3002

# --- Sessions ---
# Required for a real deployment: signs the auth cookie so it can't be tampered with.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Session cookies are only marked Secure (HTTPS-only) when APP_URL starts with
# https:// or when this is explicitly set to true. Leave it unset for plain-HTTP
# LAN use (e.g. http://192.168.0.216:3002) - browsers silently drop a Secure
# cookie sent over HTTP, which makes every login look like an instant expiry.
# COOKIE_SECURE=true

# --- Registration ---
# open = anyone who can reach the server can sign up | disabled = no new signups
# Tip: create the accounts you need, then set disabled to stop new signups.
REGISTRATION_MODE=open
# DEPRECATED: invite codes are no longer used for signup; this value is ignored.
# INVITE_CODES=

# --- Admin ---
# Comma-separated emails that are always promoted to the admin role on login,
# in addition to the first account ever registered. Case doesn't matter and
# extra spaces around commas are fine.
# ADMIN_EMAILS=you@example.com
# ADMIN_EMAILS=you@example.com, teammate@example.com

# --- Uploads & quota ---
MAX_UPLOAD_MB=20
# Storage quota for normal user accounts, in megabytes.
DEFAULT_USER_QUOTA_MB=5120
# Storage quota for admin accounts (role=admin, or listed in ADMIN_EMAILS).
# Accepts a number of MB, or "unlimited" / "-1" for no cap.
ADMIN_USER_QUOTA_MB=102400
TRASH_RETENTION_DAYS=30

# --- Networking / reverse proxy ---
# Public URL this instance is served at (used for documentation/display only).
# APP_URL=https://cloud.example.com
# Number of reverse proxy hops to trust (Express "trust proxy"). Use "false" to disable.
TRUST_PROXY=1

# --- Maintenance ---
MAINTENANCE_MODE=false

# --- Backups ---
# Admin-created backups (Admin -> Backups) are written to ./backups as
# .tar.gz archives of data/ and uploads/. The folder is created automatically
# and gitignored. Backups never include this .env file - keep it safe separately.
